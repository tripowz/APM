NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Required public key for browser auth and SSR session wiring.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional compatibility alias. If you use this, you do not need NEXT_PUBLIC_SUPABASE_ANON_KEY.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
# Optional, server-only: enables in-app user creation and demo seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional seed password override
SEED_DEMO_PASSWORD=ChangeMe123!
